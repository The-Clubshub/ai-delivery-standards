{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-delivery-standards.local/schemas/approval.schema.json",
  "title": "AI Delivery V2 Approval Status",
  "type": "object",
  "required": ["requirements", "plan", "implementation"],
  "properties": {
    "requirements": { "$ref": "#/$defs/gate" },
    "plan": { "$ref": "#/$defs/gate" },
    "implementation": { "$ref": "#/$defs/gate" }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "enum": ["pending", "approved", "changes_requested", "stale", "revoked", "legacy_accepted", "not_required"]
        },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  }
}

