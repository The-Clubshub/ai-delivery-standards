{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-delivery-standards.local/schemas/ai-config.schema.json",
  "title": "AI Delivery V2 Config",
  "type": "object",
  "required": ["operatingSystemVersion", "standardsPath", "aiPath", "featurePath", "approvalPolicy", "aiWorkbench"],
  "properties": {
    "operatingSystemVersion": { "const": "v2" },
    "standardsVersion": { "type": "string" },
    "standardsPath": { "type": "string" },
    "agentInstructionPath": { "type": "string" },
    "docsPath": { "type": "string" },
    "aiPath": { "type": "string" },
    "featurePath": { "type": "string" },
    "legacyFeaturePath": { "type": "string" },
    "decisionPath": { "type": "string" },
    "commandProtocol": { "type": "string" },
    "approvalPolicy": {
      "type": "object",
      "required": ["requirements", "plan", "implementation"],
      "additionalProperties": false,
      "properties": {
        "requirements": { "$ref": "#/$defs/approvalGatePolicy" },
        "plan": { "$ref": "#/$defs/approvalGatePolicy" },
        "implementation": { "$ref": "#/$defs/approvalGatePolicy" }
      }
    },
    "aiWorkbench": { "$ref": "#/$defs/aiWorkbench" },
    "requiredFeatureArtifacts": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "approvalGatePolicy": {
      "type": "string",
      "enum": ["human_required", "not_required"],
      "description": "human_required requires explicit human approval; not_required lets the responsible agent advance after required artifacts and evidence are ready."
    },
    "aiWorkbench": {
      "type": "object",
      "required": ["provider", "mode", "stageModels"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["codex", "claude", "cursor"],
          "description": "Desktop app or CLI used for AI delivery work."
        },
        "mode": {
          "type": "string",
          "enum": ["desktop_or_cli"]
        },
        "stageModels": {
          "type": "object",
          "required": ["requirements", "planning", "building", "reviewing", "testing", "syncCompletion", "highRiskReview"],
          "additionalProperties": false,
          "properties": {
            "requirements": { "$ref": "#/$defs/modelName" },
            "planning": { "$ref": "#/$defs/modelName" },
            "building": { "$ref": "#/$defs/modelName" },
            "reviewing": { "$ref": "#/$defs/modelName" },
            "testing": { "$ref": "#/$defs/modelName" },
            "syncCompletion": { "$ref": "#/$defs/modelName" },
            "highRiskReview": { "$ref": "#/$defs/modelName" }
          }
        }
      }
    },
    "modelName": {
      "type": "string",
      "minLength": 1,
      "description": "Model label as exposed by the selected workbench. Use workbench-default to use the current default."
    }
  }
}
